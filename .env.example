# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled URL — used by the runtime (Prisma at request time)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.pooler.neon.tech/zikel?sslmode=require&pgbouncer=true

# Direct URL — used by Prisma Migrate only
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.neon.tech/zikel?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — use `openssl rand -hex 32` to generate
JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=12h
SESSION_IDLE_TIMEOUT=15m
SESSION_WARNING_WINDOW_SECONDS=300
AUTH_REFRESH_COOKIE_NAME=__Host-zikel_rt
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_PATH=/
# AUTH_REFRESH_COOKIE_DOMAIN=
# Backward compatibility bridge. Set to false after FE fully migrates to HttpOnly cookie refresh.
AUTH_LEGACY_REFRESH_TOKEN_IN_BODY=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
CORS_ORIGINS=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Email (Resend — https://resend.com) ──────────────────────────────────────
# Not required in development — OTPs are logged to the console instead.
# Required in production: set these via your host secret manager.
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Swagger / OpenAPI ────────────────────────────────────────────────────────
# Auto-enabled in development only.
# Override explicitly if needed. Docs served at GET /docs
# SWAGGER_ENABLED=true
# Required when SWAGGER_ENABLED=true outside development.
# SWAGGER_BASIC_AUTH_USERNAME=docs_admin
# SWAGGER_BASIC_AUTH_PASSWORD=replace-with-long-password

# ─── Public URL (email assets) ────────────────────────────────────────────────
# Used to render absolute image URLs in outgoing emails (e.g. logo SVG).
# PUBLIC_BASE_URL=https://your-backend.onrender.com

# ─── AI (optional, with backend fallback when disabled/unavailable) ───────────
# AI_ENABLED=false
# AI_API_KEY=your_openai_api_key_here
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1
# AI_TIMEOUT_MS=12000
# AI context hardening
# AI_CONTEXT_REDACTION_ENABLED=true
# AI_CONTEXT_REDACTION_MODE=strict
# AI_CONTEXT_REDACTION_SENSITIVE_KEYS=firstName,lastName,middleName,fullName,name,email,phone,phoneNumber,address,dob,dateOfBirth,niNumber,nhsNumber,medical,diagnosis,passport

# ─── Security Alerts (real-time webhook pipeline) ────────────────────────────
# Enable/disable queue+dispatch pipeline.
# SECURITY_ALERT_PIPELINE_ENABLED=true
# Webhook URL is required in staging/production when pipeline is enabled.
# To use this backend as the receiver, point to:
# SECURITY_ALERT_WEBHOOK_URL=https://your-backend.onrender.com/api/v1/integrations/security-alerts/webhook
# For external receivers (e.g. SIEM/incident tooling), use their HTTPS endpoint.
# SECURITY_ALERT_WEBHOOK_URL=https://hooks.your-org.com/zikel/security-alerts
# Required in staging/production when pipeline is enabled.
# Must be at least 16 characters.
# SECURITY_ALERT_WEBHOOK_SHARED_SECRET=replace-with-long-random-secret
# SECURITY_ALERT_WEBHOOK_TIMEOUT_MS=5000
# Allowed signature timestamp drift in seconds (default 300).
# SECURITY_ALERT_WEBHOOK_MAX_DRIFT_SECONDS=300

# ─── Safeguarding Risk Backfill Scheduler ────────────────────────────────────
# Runs periodic scheduled evaluations for safeguarding risk escalation alerts.
# Keep disabled unless you want automatic backfill runs from this process.
# SAFEGUARDING_RISK_BACKFILL_ENABLED=false
# SAFEGUARDING_RISK_BACKFILL_INTERVAL_MINUTES=30
# SAFEGUARDING_RISK_BACKFILL_LOOKBACK_HOURS=168
# SAFEGUARDING_RISK_BACKFILL_RUN_ON_STARTUP=true
# SAFEGUARDING_RISK_BACKFILL_SEND_EMAIL_HOOKS=false
# Retention + confidentiality hardening
# SAFEGUARDING_CHRONOLOGY_RETENTION_DAYS=365
# SAFEGUARDING_PATTERNS_RETENTION_DAYS=365
# SAFEGUARDING_RISK_ALERT_RETENTION_DAYS=365
# SAFEGUARDING_CONFIDENTIALITY_DEFAULT_SCOPE=standard

# ─── Therapeutic Rollout (Phase 9) ──────────────────────────────────────────
# Module feature flags
# THERAPEUTIC_REG_PACKS_ENABLED=true
# THERAPEUTIC_CHRONOLOGY_ENABLED=true
# THERAPEUTIC_RISK_ALERTS_ENABLED=true
# THERAPEUTIC_PATTERNS_ENABLED=true
# THERAPEUTIC_RI_DASHBOARD_ENABLED=true
# THERAPEUTIC_REFLECTIVE_PROMPTS_ENABLED=true
# Pilot allowlist rollout
# THERAPEUTIC_PILOT_MODE_ENABLED=false
# THERAPEUTIC_PILOT_TENANT_IDS=mig_legacy_tenant
# Telemetry controls
# THERAPEUTIC_TELEMETRY_ENABLED=true
# THERAPEUTIC_ROLLOUT_WAVE_LABEL=wave_1_internal

# ─── File Uploads (S3-compatible object storage) ─────────────────────────────
# Direct-to-storage upload flow:
# 1) FE requests presigned PUT URL from backend
# 2) FE uploads file directly to storage
# 3) FE calls complete endpoint, then stores fileId in task/document payload
#
# UPLOADS_ENABLED=true
# UPLOADS_S3_BUCKET=zikel-uploads
# UPLOADS_S3_REGION=eu-west-1
# Optional for S3-compatible providers (R2/Wasabi/MinIO):
# UPLOADS_S3_ENDPOINT=https://<account-or-provider-endpoint>
# UPLOADS_S3_ACCESS_KEY_ID=replace-me
# UPLOADS_S3_SECRET_ACCESS_KEY=replace-me
# UPLOADS_FORCE_PATH_STYLE=false
# UPLOADS_SIGNED_URL_TTL_SECONDS=900
# UPLOADS_MAX_FILE_SIZE_BYTES=15728640
# Comma-separated allowlist
# UPLOADS_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,image/webp,image/svg+xml
# Optional public CDN/base URL to expose stable file links:
# UPLOADS_PUBLIC_BASE_URL=https://cdn.zikelsolutions.com
