// This is the Prisma schema for Zikel Solutions BE.
// Run `npx prisma migrate dev` to apply changes.
// Run `npx prisma generate` to regenerate the client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Country {
  UK
  Nigeria
}

enum Gender {
  male
  female
  other
}

enum UserRole {
  staff
  manager
  admin
}

enum PlatformRole {
  platform_admin
  support
  engineer
  billing
}

enum TenantRole {
  tenant_admin
  sub_admin
  staff
}

enum MembershipStatus {
  invited
  active
  suspended
  revoked
}

enum OtpPurpose {
  email_verification
  password_reset
  mfa_challenge
  staff_activation
}

enum MfaType {
  totp
}

enum InvitationStatus {
  pending
  accepted
  revoked
  // Note: `expired` is derived at read time from expiresAt < now while status=pending.
  // No background job flips pending→expired; queries treat the two as equivalent.
}

enum AuditAction {
  login
  logout
  register
  password_change
  otp_verified
  record_created
  record_accessed
  record_updated
  record_deleted
  permission_changed
}

enum SecurityAlertType {
  repeated_auth_failures
  cross_tenant_attempts
  admin_changes
  break_glass_access
}

enum SecurityAlertSeverity {
  medium
  high
}

enum SecurityAlertDeliveryStatus {
  pending
  delivered
  failed
}

enum SafeguardingRiskAlertType {
  high_severity_incident
  repeated_incident_pattern
  rejected_approval_spike
  overdue_high_priority_tasks
  critical_home_event_signal
}

enum SafeguardingRiskAlertSeverity {
  medium
  high
  critical
}

enum SafeguardingRiskAlertStatus {
  new
  acknowledged
  in_progress
  resolved
}

enum SafeguardingRiskAlertTargetType {
  tenant
  home
  young_person
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskApprovalStatus {
  not_required
  pending_approval
  approved
  rejected
  processing
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskCategory {
  task_log
  document
  system_link
  checklist
  incident
  other
  daily_log
  reward
}

enum TaskReferenceType {
  entity
  upload
  internal_route
  external_url
  document_url
}

enum TaskReferenceEntityType {
  tenant
  care_group
  home
  young_person
  vehicle
  employee
  task
}

enum UploadPurpose {
  signature
  task_attachment
  task_document
  announcement_image
  general
}

enum UploadStatus {
  pending
  uploaded
  failed
}

enum DocumentVisibility {
  private
  tenant
  home
}

enum ExportJobEntity {
  homes
  employees
  young_people
  vehicles
  care_groups
  tasks
  daily_logs
  audit
}

enum ExportJobFormat {
  pdf
  excel
  csv
}

enum ExportJobStatus {
  pending
  processing
  completed
  failed
}

enum GroupingType {
  operational
  reporting
  custom
}

enum GroupingEntityType {
  home
  employee
  care_group
}

enum SensitiveDataConfidentialityScope {
  restricted
  confidential
  highly_confidential
}

// ─── Help Center ─────────────────────────────────────────────────────────────

enum TicketStatus {
  open
  in_progress
  waiting_on_customer
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketCategory {
  bug_report
  feature_request
  account_issue
  billing
  technical_support
  general_question
  other
}

// ─── Notifications ───────────────────────────────────────────────────────────

enum NotificationLevel {
  platform
  tenant
}

enum NotificationCategory {
  maintenance
  new_feature
  policy_change
  platform_announcement
  task_assigned
  task_approved
  task_rejected
  task_completed
  task_overdue
  employee_added
  announcement_posted
  shift_changed
  daily_log_submitted
  ticket_update
  general
}

// ─── Public / Marketing ───────────────────────────────────────────────────────

enum ServiceOfInterest {
  care_documentation_platform
  ai_staff_guidance
  training_development
  healthcare_workflow
  general_enquiry
}

model DemoRequest {
  id                    String            @id @default(cuid())
  fullName              String
  organisationName      String?
  rolePosition          String?
  email                 String
  phoneNumber           String?
  numberOfStaffChildren String?
  serviceOfInterest     ServiceOfInterest
  keyChallenges         String?
  message               String?
  source                String?
  createdAt             DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

model ContactMessage {
  id                String            @id @default(cuid())
  fullName          String
  email             String
  phoneNumber       String
  serviceOfInterest ServiceOfInterest
  message           String?
  source            String?
  createdAt         DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

model WaitlistEntry {
  id                String            @id @default(cuid())
  fullName          String
  email             String
  organisation      String?
  serviceOfInterest ServiceOfInterest
  source            String?
  createdAt         DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model TenantUser {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String
  role                     UserRole  @default(staff)
  firstName                String
  middleName               String?
  lastName                 String
  gender                   Gender?
  country                  Country   @default(UK)
  phoneNumber              String?
  avatarUrl                String?
  language                 String    @default("en")
  timezone                 String    @default("Europe/London")
  emailVerified            Boolean   @default(false)
  acceptedTerms            Boolean   @default(false)
  isActive                 Boolean   @default(true)
  // Phase 8.1 (2026-05-09): default flipped to true. Tenant-paid AI access is
  // now the default; this flag remains as a per-user *deny-list* override that
  // a tenant Owner can set to revoke AI access from a specific staff member.
  aiAccessEnabled          Boolean   @default(true)
  userType                 String    @default("internal")
  dateOfBirth              DateTime?
  otherNames               String?
  landingPage              String?
  hideFutureTasks          Boolean   @default(false)
  enableIpRestriction      Boolean   @default(false)
  passwordExpiresInstantly Boolean   @default(false)
  disableLoginAt           DateTime?
  passwordExpiresAt        DateTime?
  activeTenantId           String?
  lastLoginAt              DateTime?
  failedAttempts           Int       @default(0)
  lockedUntil              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  activeTenant                       Tenant?                     @relation("UserActiveTenant", fields: [activeTenantId], references: [id], onDelete: SetNull)
  sessions                           TenantSession[]
  refreshTokens                      RefreshToken[]
  otpCodes                           OtpCode[]
  mfaCredential                      TenantMfaCredential?
  mfaBackupCodes                     TenantMfaBackupCode[]
  invitationsSent                    Invitation[]                @relation("InvitationInviter")
  invitationsAccepted                Invitation[]                @relation("InvitationAccepter")
  impersonationGrantsAsTarget        ImpersonationGrant[]        @relation("ImpersonationGrantTargetUser")
  auditLogs                          AuditLog[]
  securityAlertDeliveries            SecurityAlertDelivery[]
  tenantMemberships                  TenantMembership[]          @relation("UserTenantMemberships")
  sentTenantInvites                  TenantMembership[]          @relation("UserTenantInvites")
  tenantInvitationsSent              TenantInvite[]              @relation("UserSentTenantInvites")
  tenantInvitationsAccepted          TenantInvite[]              @relation("UserAcceptedTenantInvites")
  tenantInviteLinksCreated           TenantInviteLink[]          @relation("UserCreatedTenantInviteLinks")
  employees                          Employee[]
  widgets                            Widget[]
  announcementReads                  AnnouncementRead[]
  taskReviewEvents                   TaskReviewEvent[]
  uploadedFiles                      UploadedFile[]              @relation("UserUploadedFiles")
  uploadedDocuments                  DocumentRecord[]            @relation("DocumentUploadedBy")
  homesAsAdmin                       Home[]                      @relation("HomeAdmin")
  homesAsPersonInCharge              Home[]                      @relation("HomePersonInCharge")
  homesAsResponsibleIndividual       Home[]                      @relation("HomeResponsibleIndividual")
  youngPeopleAsAdmin                 YoungPerson[]               @relation("YoungPersonAdmin")
  youngPeopleAsPracticeManager       YoungPerson[]               @relation("YoungPersonPracticeManager")
  faqArticles                        FaqArticle[]                @relation("UserFaqArticles")
  supportTickets                     SupportTicket[]             @relation("UserSupportTickets")
  ticketComments                     TicketComment[]             @relation("UserTicketComments")
  createdNotifications               Notification[]              @relation("UserCreatedNotifications")
  notificationRecipients             NotificationRecipient[]     @relation("UserNotificationRecipients")
  notificationPreferences            NotificationPreference[]    @relation("UserNotificationPreferences")
  exportJobsCreated                  ExportJob[]
  createdRotas                       Rota[]                      @relation("RotaCreatedBy")
  updatedRotas                       Rota[]                      @relation("RotaUpdatedBy")
  createdRotaTemplates               RotaTemplate[]              @relation("RotaTemplateCreatedBy")
  createdGroupings                   Grouping[]                  @relation("GroupingCreatedBy")
  createdSensitiveDataRecords        SensitiveDataRecord[]       @relation("SensitiveDataCreatedBy")
  updatedSensitiveDataRecords        SensitiveDataRecord[]       @relation("SensitiveDataUpdatedBy")
  sensitiveDataAccessLogs            SensitiveDataAccessLog[]
  webhookEndpoints                   WebhookEndpoint[]           @relation("UserWebhookEndpoints")
  ownedSafeguardingRiskAlerts        SafeguardingRiskAlert[]     @relation("SafeguardingRiskAlertOwner")
  acknowledgedSafeguardingRiskAlerts SafeguardingRiskAlert[]     @relation("SafeguardingRiskAlertAcknowledgedBy")
  resolvedSafeguardingRiskAlerts     SafeguardingRiskAlert[]     @relation("SafeguardingRiskAlertResolvedBy")
  safeguardingRiskAlertNotes         SafeguardingRiskAlertNote[]
  aiCallEvents                       AiCallEvent[]
  aiConversations                    AiConversation[]
  // Phase 7.2 (Day 2) — token-ledger debits attribute calls back to a user
  tokenLedgerEntries                 TokenLedgerEntry[]
  aiRestrictionsUpdated              TenantAiRestriction[]       @relation("AiRestrictionUpdatedBy")

  @@index([email])
  @@index([role])
  @@index([activeTenantId])
}

// ─── Platform identity (Zikel internal staff) ────────────────────────────────
// Strictly separated from TenantUser. Platform users authenticate via /admin/auth/*,
// receive JWTs with aud='platform', and never appear in tenant-scoped data.

model PlatformUser {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  role           PlatformRole
  firstName      String
  lastName       String
  isActive       Boolean      @default(true)
  lastLoginAt    DateTime?
  failedAttempts Int          @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sessions                    PlatformSession[]
  refreshTokens               PlatformRefreshToken[]
  auditLogs                   PlatformAuditLog[]
  mfaCredential               PlatformMfaCredential?
  mfaBackupCodes              PlatformMfaBackupCode[]
  impersonationGrants         ImpersonationGrant[]
  impersonationGrantsApproved ImpersonationGrant[]    @relation("ImpersonationGrantApprover")
  impersonatedAuditLogs       AuditLog[]              @relation("AuditLogImpersonator")

  @@index([email])
  @@index([role])
}

model PlatformSession {
  id                String    @id @default(cuid())
  platformUserId    String
  deviceLabel       String?
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())
  revokedAt         DateTime?
  mfaVerifiedAt     DateTime?
  absoluteExpiresAt DateTime

  platformUser  PlatformUser           @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  refreshTokens PlatformRefreshToken[]

  @@index([platformUserId])
  @@index([revokedAt])
  @@index([absoluteExpiresAt])
}

model PlatformRefreshToken {
  id                String    @id @default(cuid())
  sessionId         String
  platformUserId    String
  token             String    @unique
  idleExpiresAt     DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  session      PlatformSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  platformUser PlatformUser           @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  replacedBy   PlatformRefreshToken?  @relation("PlatformRefreshTokenChain", fields: [replacedByTokenId], references: [id])
  replaces     PlatformRefreshToken[] @relation("PlatformRefreshTokenChain")

  @@index([sessionId])
  @@index([platformUserId])
  @@index([token])
  @@index([idleExpiresAt])
}

model PlatformAuditLog {
  id             String      @id @default(cuid())
  platformUserId String?
  action         AuditAction
  entityType     String?
  entityId       String?
  targetTenantId String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([platformUserId])
  @@index([createdAt])
  @@index([targetTenantId])
}

// ─── Platform MFA ────────────────────────────────────────────────────────────

model PlatformMfaCredential {
  id              String    @id @default(cuid())
  platformUserId  String    @unique
  type            MfaType   @default(totp)
  // TOTP secret encrypted at rest with AES-256-GCM. See src/lib/secret-crypto.ts.
  // Format: <ivBase64>:<authTagBase64>:<ciphertextBase64>
  secretEncrypted String
  label           String?
  createdAt       DateTime  @default(now())
  // Null until the user proves possession by entering the first TOTP code at
  // setup-verify. Login MFA gating only fires when confirmedAt is not null.
  confirmedAt     DateTime?
  lastUsedAt      DateTime?

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
}

model PlatformMfaBackupCode {
  id             String    @id @default(cuid())
  platformUserId String
  // bcrypt hash of the original 8-char backup code; cannot be reversed.
  codeHash       String
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  country   Country  @default(UK)
  isActive  Boolean  @default(true)
  // Phase 8.1 (2026-05-09): tenant-level AI master switch. Flipped to false
  // automatically when subscriptionStatus enters past_due_readonly / suspended;
  // also editable by the Owner via /api/v1/billing/ai-restrictions.
  aiEnabled Boolean  @default(true)
  // Phase 7.1 (Day 2): denormalised cache of `Subscription.status` so the
  // enforcement middleware can read it on every request without a join.
  // Default `trialing` so new tenants start in a trial automatically; the
  // grandfather migration (Phase 7.9) backfills existing tenants the same way.
  subscriptionStatus SubscriptionStatus @default(trialing)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activeUsers                TenantUser[]                @relation("UserActiveTenant")
  memberships                TenantMembership[]
  invites                    TenantInvite[]
  inviteLinks                TenantInviteLink[]
  invitations                Invitation[]
  impersonationGrants        ImpersonationGrant[]        @relation("ImpersonationGrantTenant")
  careGroups                 CareGroup[]
  homes                      Home[]
  employees                  Employee[]
  homeEvents                 HomeEvent[]
  employeeShifts             EmployeeShift[]
  youngPeople                YoungPerson[]
  vehicles                   Vehicle[]
  tasks                      Task[]
  taskReferences             TaskReference[]
  announcements              Announcement[]
  widgets                    Widget[]
  auditLogs                  AuditLog[]
  securityAlertDeliveries    SecurityAlertDelivery[]
  taskReviewEvents           TaskReviewEvent[]
  uploadedFiles              UploadedFile[]
  documents                  DocumentRecord[]
  exportJobs                 ExportJob[]
  settings                   TenantSettings?
  rotas                      Rota[]
  rotaTemplates              RotaTemplate[]
  regions                    Region[]
  regionHomes                RegionHome[]
  groupings                  Grouping[]
  groupingMembers            GroupingMember[]
  sensitiveDataRecords       SensitiveDataRecord[]
  sensitiveDataAccessLogs    SensitiveDataAccessLog[]
  roles                      Role[]
  supportTickets             SupportTicket[]
  notifications              Notification[]
  webhookEndpoints           WebhookEndpoint[]
  safeguardingRiskAlerts     SafeguardingRiskAlert[]
  safeguardingRiskAlertNotes SafeguardingRiskAlertNote[]
  aiCallEvents               AiCallEvent[]
  aiConversations            AiConversation[]
  // Phase 7.1 (Day 2) — billing
  subscription               Subscription?
  invoices                   Invoice[]
  paymentMethods             PaymentMethod[]
  billingEvents              BillingEvent[]
  // Phase 7.2 (Day 2) — token metering
  tokenAllocations           TokenAllocation[]
  tokenLedgerEntries         TokenLedgerEntry[]
  aiRestriction              TenantAiRestriction?

  @@index([name])
  @@index([isActive])
}

model TenantMembership {
  id          String           @id @default(cuid())
  tenantId    String
  userId      String
  roleId      String
  status      MembershipStatus @default(active)
  invitedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      TenantUser  @relation("UserTenantMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role      Role        @relation(fields: [roleId], references: [id])
  invitedBy TenantUser? @relation("UserTenantInvites", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, roleId])
  @@index([status])
}

model TenantInvite {
  id               String     @id @default(cuid())
  tenantId         String
  email            String
  role             TenantRole
  tokenHash        String     @unique
  invitedById      String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy      TenantUser  @relation("UserSentTenantInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedByUser TenantUser? @relation("UserAcceptedTenantInvites", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([tenantId, role])
  @@index([tenantId, expiresAt])
  @@index([invitedById])
  @@index([acceptedByUserId])
}

model TenantInviteLink {
  id          String     @id @default(cuid())
  tenantId    String
  code        String     @unique
  defaultRole TenantRole @default(staff)
  isActive    Boolean    @default(true)
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy TenantUser @relation("UserCreatedTenantInviteLinks", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([code])
  @@index([createdById])
}

// ─── Invitations (Phase 5 — supersedes TenantInvite/TenantInviteLink) ───────

model Invitation {
  id               String           @id @default(cuid())
  tenantId         String
  email            String
  invitedById      String
  // Pre-assigned permission bundle on accept.
  roleId           String
  // Optional: pre-assign the new staff member to a specific home.
  homeId           String?
  // SHA-256 hash of the random plaintext token. The plaintext is sent in the
  // email link only — it is never stored. On accept we hash the presented
  // value and look up by tokenHash.
  tokenHash        String           @unique
  status           InvitationStatus @default(pending)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy      TenantUser  @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  role           Role        @relation(fields: [roleId], references: [id])
  home           Home?       @relation(fields: [homeId], references: [id], onDelete: SetNull)
  acceptedByUser TenantUser? @relation("InvitationAccepter", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([expiresAt])
}

// ─── Impersonation (Phase 5 — platform → tenant access with audit) ──────────

model ImpersonationGrant {
  id              String    @id @default(cuid())
  platformUserId  String
  targetTenantId  String
  // Optional: limit impersonation to a specific tenant user. If null, the
  // platform user impersonates the tenant Owner.
  targetUserId    String?
  // Optional: a separate platform user who approved this grant (four-eyes /
  // separation-of-duties workflow). Null if the grant was self-issued.
  grantedByUserId String?
  ticketReference String
  reason          String
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?

  platformUser PlatformUser  @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  grantedBy    PlatformUser? @relation("ImpersonationGrantApprover", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  targetTenant Tenant        @relation("ImpersonationGrantTenant", fields: [targetTenantId], references: [id], onDelete: Cascade)
  targetUser   TenantUser?   @relation("ImpersonationGrantTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([platformUserId])
  @@index([targetTenantId])
  @@index([revokedAt])
  @@index([ticketReference])
  @@index([grantedAt])
  @@index([grantedByUserId])
}

model TenantSession {
  id                String    @id @default(cuid())
  userId            String
  deviceLabel       String?
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())
  revokedAt         DateTime?
  mfaVerifiedAt     DateTime?
  absoluteExpiresAt DateTime

  user          TenantUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([revokedAt])
  @@index([absoluteExpiresAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  sessionId         String
  userId            String
  token             String    @unique
  idleExpiresAt     DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  session    TenantSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       TenantUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken?  @relation("RefreshTokenChain", fields: [replacedByTokenId], references: [id])
  replaces   RefreshToken[] @relation("RefreshTokenChain")

  @@index([sessionId])
  @@index([userId])
  @@index([token])
  @@index([idleExpiresAt])
}

model OtpCode {
  id        String     @id @default(cuid())
  userId    String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  user TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

// ─── Tenant MFA ──────────────────────────────────────────────────────────────

model TenantMfaCredential {
  id              String    @id @default(cuid())
  userId          String    @unique
  type            MfaType   @default(totp)
  // TOTP secret encrypted at rest with AES-256-GCM. See src/lib/secret-crypto.ts.
  // Format: <ivBase64>:<authTagBase64>:<ciphertextBase64>
  secretEncrypted String
  label           String?
  createdAt       DateTime  @default(now())
  // Null until the user proves possession by entering the first TOTP code at
  // setup-verify. Login MFA gating only fires when confirmedAt is not null.
  confirmedAt     DateTime?
  lastUsedAt      DateTime?

  user TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TenantMfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  // bcrypt hash of the original 8-char backup code; cannot be reversed.
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Care Groups & Homes ──────────────────────────────────────────────────────

model CareGroup {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  type         String?
  managerName  String?
  contactName  String?
  phoneNumber  String?
  email        String?
  fax          String?
  website      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  county       String?
  postcode     String?
  country      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  homes  Home[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([name])
}

model Home {
  id                      String    @id @default(cuid())
  tenantId                String
  careGroupId             String
  name                    String
  description             String?
  address                 String?
  postCode                String?
  capacity                Int?
  category                String?
  region                  String?
  status                  String    @default("current")
  phoneNumber             String?
  email                   String?
  avatarFileId            String?
  avatarUrl               String?
  adminUserId             String?
  personInChargeId        String?
  responsibleIndividualId String?
  startDate               DateTime?
  endDate                 DateTime?
  isSecure                Boolean   @default(false)
  shortTermStays          Boolean   @default(false)
  minAgeGroup             Int?
  maxAgeGroup             Int?
  ofstedUrn               String?
  compliance              Json?
  details                 Json?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  careGroup              CareGroup               @relation(fields: [careGroupId], references: [id])
  avatarFile             UploadedFile?           @relation("HomeAvatarFile", fields: [avatarFileId], references: [id], onDelete: SetNull)
  admin                  TenantUser?             @relation("HomeAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  personInCharge         TenantUser?             @relation("HomePersonInCharge", fields: [personInChargeId], references: [id], onDelete: SetNull)
  responsibleIndividual  TenantUser?             @relation("HomeResponsibleIndividual", fields: [responsibleIndividualId], references: [id], onDelete: SetNull)
  employees              Employee[]
  youngPeople            YoungPerson[]
  vehicles               Vehicle[]
  tasks                  Task[]
  events                 HomeEvent[]
  shifts                 EmployeeShift[]
  rotas                  Rota[]
  documents              DocumentRecord[]
  regionLinks            RegionHome[]
  rotaTemplates          RotaTemplate[]
  sensitiveDataRecords   SensitiveDataRecord[]
  safeguardingRiskAlerts SafeguardingRiskAlert[]
  invitations            Invitation[]

  @@index([tenantId])
  @@index([careGroupId])
  @@index([avatarFileId])
  @@index([status])
}

// ─── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  homeId         String?
  jobTitle       String?
  startDate      DateTime?
  endDate        DateTime?
  status         String    @default("current")
  contractType   String?
  dbsNumber      String?
  dbsDate        DateTime?
  qualifications Json?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant                 Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                   TenantUser      @relation(fields: [userId], references: [id])
  home                   Home?           @relation(fields: [homeId], references: [id])
  tasks                  Task[]          @relation("TaskAssignee")
  approvedTasks          Task[]          @relation("TaskApprover")
  shifts                 EmployeeShift[]
  youngPeopleAsKeyWorker YoungPerson[]   @relation("YoungPersonKeyWorker")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([homeId])
  @@index([status])
}

// ─── Roles ───────────────────────────────────────────────────────────────────

model Role {
  id           String   @id @default(cuid())
  tenantId     String? // null = system role (shared template across all tenants)
  name         String
  description  String?
  permissions  String[] // Array of Permission strings — see src/auth/permissions.ts
  isActive     Boolean  @default(true)
  isSystemRole Boolean  @default(false)
  isAssignable Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TenantMembership[]
  invitations Invitation[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isSystemRole])
}

// ─── Home Events & Shifts ────────────────────────────────────────────────────

model HomeEvent {
  id          String    @id @default(cuid())
  tenantId    String
  homeId      String
  title       String
  description String?
  type        String    @default("other")
  attendeeIds String[]  @default([])
  recurrence  Json?
  allDay      Boolean   @default(false)
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home   Home   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([tenantId, startsAt])
  @@index([tenantId, type, startsAt])
  @@index([homeId, startsAt])
}

model EmployeeShift {
  id         String   @id @default(cuid())
  tenantId   String
  homeId     String
  employeeId String
  startTime  DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home     Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, startTime])
  @@index([homeId, startTime])
  @@index([employeeId, startTime])
}

// ─── Young People ─────────────────────────────────────────────────────────────

model YoungPerson {
  id                          String    @id @default(cuid())
  tenantId                    String
  homeId                      String
  firstName                   String
  lastName                    String
  preferredName               String?
  namePronunciation           String?
  description                 String?
  dateOfBirth                 DateTime?
  gender                      String?
  ethnicity                   String?
  religion                    String?
  referenceNo                 String?
  niNumber                    String?
  roomNumber                  String?
  status                      String    @default("current")
  type                        String?
  admissionDate               DateTime?
  placementEndDate            DateTime?
  avatarFileId                String?
  avatarUrl                   String?
  keyWorkerId                 String?
  practiceManagerId           String?
  adminUserId                 String?
  socialWorkerName            String?
  independentReviewingOfficer String?
  placingAuthority            String?
  legalStatus                 String?
  isEmergencyPlacement        Boolean   @default(false)
  isAsylumSeeker              Boolean   @default(false)
  contact                     Json?
  health                      Json?
  education                   Json?
  isActive                    Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home                   Home                    @relation(fields: [homeId], references: [id])
  avatarFile             UploadedFile?           @relation("YoungPersonAvatarFile", fields: [avatarFileId], references: [id], onDelete: SetNull)
  keyWorker              Employee?               @relation("YoungPersonKeyWorker", fields: [keyWorkerId], references: [id], onDelete: SetNull)
  practiceManager        TenantUser?             @relation("YoungPersonPracticeManager", fields: [practiceManagerId], references: [id], onDelete: SetNull)
  admin                  TenantUser?             @relation("YoungPersonAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  tasks                  Task[]
  safeguardingRiskAlerts SafeguardingRiskAlert[]
  sensitiveDataRecords   SensitiveDataRecord[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId])
  @@index([homeId])
  @@index([status])
  @@index([lastName, firstName])
}

// ─── Vehicles ─────────────────────────────────────────────────────────────────

model Vehicle {
  id               String    @id @default(cuid())
  tenantId         String
  homeId           String?
  registration     String    @unique
  make             String?
  model            String?
  year             Int?
  colour           String?
  description      String?
  status           String    @default("current")
  vin              String?
  registrationDate DateTime?
  taxDate          DateTime?
  fuelType         String?
  insuranceDate    DateTime?
  ownership        String?
  leaseStartDate   DateTime?
  leaseEndDate     DateTime?
  purchasePrice    Decimal?
  purchaseDate     DateTime?
  startDate        DateTime?
  endDate          DateTime?
  adminUserId      String?
  contactPhone     String?
  avatarFileId     String?
  avatarUrl        String?
  mileage          Int?
  details          Json?
  isActive         Boolean   @default(true)
  nextServiceDue   DateTime?
  motDue           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home       Home?         @relation(fields: [homeId], references: [id], onDelete: SetNull)
  avatarFile UploadedFile? @relation("VehicleAvatarFile", fields: [avatarFileId], references: [id], onDelete: SetNull)
  tasks      Task[]

  @@index([tenantId])
  @@index([registration])
  @@index([homeId])
  @@index([avatarFileId])
  @@index([status])
}

// ─── Form Templates ───────────────────────────────────────────────────────────

model FormTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  group       String
  schemaJson  Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks Task[]

  @@index([name])
  @@index([group])
  @@index([isActive])
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id                String             @id @default(cuid())
  tenantId          String
  category          TaskCategory       @default(task_log)
  formTemplateKey   String?
  formName          String?
  formGroup         String?
  submissionPayload Json?
  signatureFileId   String?
  submittedAt       DateTime?
  submittedById     String?
  updatedById       String?
  title             String
  description       String?
  status            TaskStatus         @default(pending)
  approvalStatus    TaskApprovalStatus @default(not_required)
  priority          TaskPriority       @default(medium)
  dueDate           DateTime?
  completedAt       DateTime?
  rejectionReason   String?
  approvedAt        DateTime?
  assigneeId        String?
  approvedById      String?
  homeId            String?
  vehicleId         String?
  youngPersonId     String?
  createdById       String?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formTemplate  FormTemplate?     @relation(fields: [formTemplateKey], references: [key], onDelete: SetNull)
  assignee      Employee?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  approvedBy    Employee?         @relation("TaskApprover", fields: [approvedById], references: [id])
  home          Home?             @relation(fields: [homeId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  youngPerson   YoungPerson?      @relation(fields: [youngPersonId], references: [id])
  signatureFile UploadedFile?     @relation("TaskSignatureFile", fields: [signatureFileId], references: [id], onDelete: SetNull)
  references    TaskReference[]
  reviewEvents  TaskReviewEvent[]

  @@index([tenantId])
  @@index([formTemplateKey])
  @@index([formGroup])
  @@index([status, priority])
  @@index([approvalStatus])
  @@index([category])
  @@index([assigneeId])
  @@index([homeId])
  @@index([vehicleId])
  @@index([signatureFileId])
  @@index([dueDate])
  @@index([createdById])
  @@index([submittedById])
  @@index([updatedById])
  @@index([deletedAt])
}

model TaskReviewEvent {
  id         String   @id @default(cuid())
  tenantId   String
  taskId     String
  userId     String
  action     String
  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([tenantId, userId, reviewedAt])
  @@index([taskId])
}

model TaskReference {
  id         String                   @id @default(cuid())
  tenantId   String
  taskId     String
  type       TaskReferenceType
  entityType TaskReferenceEntityType?
  entityId   String?
  fileId     String?
  url        String?
  label      String?
  metadata   Json?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task   Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file   UploadedFile? @relation("TaskReferenceFile", fields: [fileId], references: [id], onDelete: SetNull)

  @@index([tenantId, taskId])
  @@index([tenantId, type])
  @@index([entityType, entityId])
  @@index([fileId])
}

model UploadedFile {
  id             String        @id @default(cuid())
  tenantId       String
  uploadedById   String?
  storageKey     String        @unique
  originalName   String
  contentType    String
  sizeBytes      Int
  purpose        UploadPurpose @default(general)
  status         UploadStatus  @default(pending)
  checksumSha256 String?
  etag           String?
  metadata       Json?
  uploadedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy         TenantUser?      @relation("UserUploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  homeAvatars        Home[]           @relation("HomeAvatarFile")
  vehicleAvatars     Vehicle[]        @relation("VehicleAvatarFile")
  youngPersonAvatars YoungPerson[]    @relation("YoungPersonAvatarFile")
  taskSignatures     Task[]           @relation("TaskSignatureFile")
  taskReferences     TaskReference[]  @relation("TaskReferenceFile")
  documents          DocumentRecord[] @relation("DocumentFile")

  @@index([tenantId, purpose, status])
  @@index([tenantId, createdAt])
  @@index([uploadedById])
  @@index([deletedAt])
}

model DocumentRecord {
  id           String             @id @default(cuid())
  tenantId     String
  fileId       String
  homeId       String?
  uploadedById String?
  title        String
  description  String?
  category     String
  visibility   DocumentVisibility @default(tenant)
  tags         String[]           @default([])
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  file       UploadedFile @relation("DocumentFile", fields: [fileId], references: [id], onDelete: Cascade)
  home       Home?        @relation(fields: [homeId], references: [id], onDelete: SetNull)
  uploadedBy TenantUser?  @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, category])
  @@index([tenantId, createdAt])
  @@index([fileId])
  @@index([homeId])
  @@index([uploadedById])
  @@index([deletedAt])
}

model ExportJob {
  id           String          @id @default(cuid())
  tenantId     String
  createdById  String
  entity       ExportJobEntity
  filters      Json?
  format       ExportJobFormat
  status       ExportJobStatus @default(pending)
  errorMessage String?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy TenantUser @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, entity, createdAt])
  @@index([createdById, createdAt])
}

model TenantSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  timezone             String   @default("Europe/London")
  locale               String   @default("en-GB")
  dateFormat           String   @default("DD/MM/YYYY")
  logoUrl              String?
  notificationDefaults Json?
  passwordPolicy       Json?
  sessionTimeout       Int?
  mfaRequired          Boolean  @default(false)
  ipRestriction        Json?
  dataRetentionDays    Int?
  emailNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(true)
  digestFrequency      String   @default("daily")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Rota {
  id           String   @id @default(cuid())
  tenantId     String
  homeId       String
  weekStarting DateTime
  shifts       Json
  createdById  String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home      Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
  createdBy TenantUser? @relation("RotaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy TenantUser? @relation("RotaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, homeId, weekStarting])
  @@index([tenantId, weekStarting])
  @@index([homeId, weekStarting])
  @@index([createdById])
  @@index([updatedById])
}

model RotaTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  homeId      String?
  name        String
  shifts      Json
  createdById String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home      Home?       @relation(fields: [homeId], references: [id], onDelete: SetNull)
  createdBy TenantUser? @relation("RotaTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, homeId, createdAt])
  @@index([createdById])
}

model Region {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  homeLinks RegionHome[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive, createdAt])
}

model RegionHome {
  id        String   @id @default(cuid())
  tenantId  String
  regionId  String
  homeId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  home   Home   @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([regionId, homeId])
  @@index([tenantId, homeId])
  @@index([tenantId, regionId])
}

model Grouping {
  id          String             @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        GroupingType       @default(custom)
  entityType  GroupingEntityType
  isActive    Boolean            @default(true)
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy TenantUser?      @relation("GroupingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members   GroupingMember[]

  @@unique([tenantId, name, entityType])
  @@index([tenantId, type, isActive, createdAt])
  @@index([createdById])
}

model GroupingMember {
  id         String   @id @default(cuid())
  tenantId   String
  groupingId String
  entityId   String
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grouping Grouping @relation(fields: [groupingId], references: [id], onDelete: Cascade)

  @@unique([groupingId, entityId])
  @@index([tenantId, entityId])
}

model SensitiveDataRecord {
  id                   String                            @id @default(cuid())
  tenantId             String
  title                String
  category             String
  content              String
  youngPersonId        String?
  homeId               String?
  confidentialityScope SensitiveDataConfidentialityScope @default(confidential)
  retentionDate        DateTime?
  attachmentFileIds    String[]                          @default([])
  createdById          String
  updatedById          String?
  deletedAt            DateTime?
  createdAt            DateTime                          @default(now())
  updatedAt            DateTime                          @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  youngPerson YoungPerson?             @relation(fields: [youngPersonId], references: [id], onDelete: SetNull)
  home        Home?                    @relation(fields: [homeId], references: [id], onDelete: SetNull)
  createdBy   TenantUser               @relation("SensitiveDataCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   TenantUser?              @relation("SensitiveDataUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  accessLogs  SensitiveDataAccessLog[]

  @@index([tenantId, category, createdAt])
  @@index([tenantId, confidentialityScope, createdAt])
  @@index([youngPersonId])
  @@index([homeId])
  @@index([createdById])
  @@index([deletedAt])
}

model SensitiveDataAccessLog {
  id        String   @id @default(cuid())
  tenantId  String
  recordId  String
  userId    String
  action    String   @default("view")
  createdAt DateTime @default(now())

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  record SensitiveDataRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user   TenantUser          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, recordId, createdAt])
  @@index([userId, createdAt])
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id          String             @id @default(cuid())
  tenantId    String
  title       String
  body        String
  images      String[]           @default([])
  publishedAt DateTime           @default(now())
  expiresAt   DateTime?
  authorId    String?
  isPinned    Boolean            @default(false)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reads       AnnouncementRead[]

  @@index([tenantId])
  @@index([publishedAt])
  @@index([isPinned])
  @@index([deletedAt])
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         TenantUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
  @@index([readAt])
}

// ─── Dashboard Widgets ────────────────────────────────────────────────────────

model Widget {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  period    String // e.g. "last_7_days", "last_30_days", "this_month", "this_year"
  reportsOn String // e.g. "tasks", "approvals", "young_people"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  tenantId       String?
  userId         String?
  // Phase 5: when an action was performed by a Zikel platform user via an
  // active ImpersonationGrant, this is set to the platform user's id. The
  // audit-log Prisma extension auto-stamps it from request context, so the
  // trail is "what looked like userId X actually came from platform Y".
  impersonatorId String?
  action         AuditAction
  entityType     String?
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  tenant                Tenant?                @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user                  TenantUser?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  impersonator          PlatformUser?          @relation("AuditLogImpersonator", fields: [impersonatorId], references: [id], onDelete: SetNull)
  securityAlertDelivery SecurityAlertDelivery?

  @@index([tenantId])
  @@index([userId])
  @@index([impersonatorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SecurityAlertDelivery {
  id           String                      @id @default(cuid())
  auditLogId   String                      @unique
  tenantId     String?
  userId       String?
  type         SecurityAlertType
  severity     SecurityAlertSeverity
  status       SecurityAlertDeliveryStatus @default(pending)
  attemptCount Int                         @default(0)
  lastError    String?
  payload      Json
  webhookUrl   String?
  dispatchedAt DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  auditLog AuditLog    @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  tenant   Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user     TenantUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([userId, type, createdAt])
}

model SafeguardingRiskAlert {
  id               String                          @id @default(cuid())
  tenantId         String
  type             SafeguardingRiskAlertType
  severity         SafeguardingRiskAlertSeverity
  status           SafeguardingRiskAlertStatus     @default(new)
  targetType       SafeguardingRiskAlertTargetType
  targetId         String
  homeId           String?
  youngPersonId    String?
  ruleKey          String
  dedupeKey        String
  title            String
  description      String
  evidence         Json?
  windowStart      DateTime?
  windowEnd        DateTime?
  firstTriggeredAt DateTime                        @default(now())
  lastTriggeredAt  DateTime                        @default(now())
  triggeredCount   Int                             @default(1)
  ownerUserId      String?
  acknowledgedById String?
  acknowledgedAt   DateTime?
  resolvedById     String?
  resolvedAt       DateTime?
  lastEvaluatedAt  DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  home           Home?                       @relation(fields: [homeId], references: [id], onDelete: SetNull)
  youngPerson    YoungPerson?                @relation(fields: [youngPersonId], references: [id], onDelete: SetNull)
  ownerUser      TenantUser?                 @relation("SafeguardingRiskAlertOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  acknowledgedBy TenantUser?                 @relation("SafeguardingRiskAlertAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  resolvedBy     TenantUser?                 @relation("SafeguardingRiskAlertResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  notes          SafeguardingRiskAlertNote[]

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, severity, updatedAt])
  @@index([tenantId, type, lastTriggeredAt])
  @@index([homeId, status])
  @@index([youngPersonId, status])
  @@index([ownerUserId, status])
}

model SafeguardingRiskAlertNote {
  id           String   @id @default(cuid())
  alertId      String
  tenantId     String
  userId       String
  note         String
  isEscalation Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  alert  SafeguardingRiskAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@index([tenantId, createdAt])
  @@index([userId])
}

// ─── Help Center: FAQ ────────────────────────────────────────────────────────

model FaqArticle {
  id          String    @id @default(cuid())
  title       String
  body        String
  category    String
  tags        String[]  @default([])
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy TenantUser? @relation("UserFaqArticles", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isPublished])
  @@index([deletedAt])
}

// ─── Help Center: Support Tickets ────────────────────────────────────────────

model SupportTicket {
