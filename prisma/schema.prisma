// This is the Prisma schema for Zikel Solutions BE.
// Run `npx prisma migrate dev` to apply changes.
// Run `npx prisma generate` to regenerate the client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Country {
  UK
  Nigeria
}

enum Gender {
  male
  female
  other
}

enum UserRole {
  staff
  manager
  admin
}

enum OtpPurpose {
  email_verification
  password_reset
}

enum AuditAction {
  login
  logout
  register
  password_change
  otp_verified
  record_created
  record_updated
  record_deleted
  permission_changed
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskApprovalStatus {
  not_required
  pending_approval
  approved
  rejected
  processing
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

// ─── Public / Marketing ───────────────────────────────────────────────────────

enum ServiceOfInterest {
  digital_filing_cabinet
  ai_staff_guidance
  training_development
  healthcare_workflow
  general_enquiry
}

model DemoRequest {
  id                     String            @id @default(cuid())
  fullName               String
  organisationName       String?
  rolePosition           String?
  email                  String
  phoneNumber            String?
  numberOfStaffChildren  String?
  serviceOfInterest      ServiceOfInterest
  keyChallenges          String?
  message                String?
  source                 String?
  createdAt              DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

model WaitlistEntry {
  id                String            @id @default(cuid())
  fullName          String
  email             String
  organisation      String?
  serviceOfInterest ServiceOfInterest
  source            String?
  createdAt         DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(staff)
  firstName      String
  middleName     String?
  lastName       String
  gender         Gender?
  country        Country   @default(UK)
  phoneNumber    String?
  avatarUrl      String?
  emailVerified  Boolean   @default(false)
  acceptedTerms  Boolean   @default(false)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  otpCodes       OtpCode[]
  auditLogs      AuditLog[]
  employee       Employee?
  widgets        Widget[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OtpCode {
  id        String     @id @default(cuid())
  userId    String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

// ─── Care Groups & Homes ──────────────────────────────────────────────────────

model CareGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homes       Home[]

  @@index([name])
}

model Home {
  id          String    @id @default(cuid())
  careGroupId String
  name        String
  address     String?
  capacity    Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  careGroup   CareGroup   @relation(fields: [careGroupId], references: [id])
  employees   Employee[]
  youngPeople YoungPerson[]

  @@index([careGroupId])
}

// ─── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id          String    @id @default(cuid())
  userId      String    @unique
  homeId      String?
  jobTitle    String?
  startDate   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  home        Home?     @relation(fields: [homeId], references: [id])
  tasks       Task[]    @relation("TaskAssignee")
  approvedTasks Task[]  @relation("TaskApprover")

  @@index([homeId])
}

// ─── Young People ─────────────────────────────────────────────────────────────

model YoungPerson {
  id          String    @id @default(cuid())
  homeId      String
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  referenceNo String?   @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  home        Home      @relation(fields: [homeId], references: [id])
  tasks       Task[]

  @@index([homeId])
  @@index([lastName, firstName])
}

// ─── Vehicles ─────────────────────────────────────────────────────────────────

model Vehicle {
  id             String    @id @default(cuid())
  registration   String    @unique
  make           String?
  model          String?
  year           Int?
  colour         String?
  isActive       Boolean   @default(true)
  nextServiceDue DateTime?
  motDue         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([registration])
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id               String             @id @default(cuid())
  title            String
  description      String?
  status           TaskStatus         @default(pending)
  approvalStatus   TaskApprovalStatus @default(not_required)
  priority         TaskPriority       @default(medium)
  dueDate          DateTime?
  completedAt      DateTime?
  rejectionReason  String?
  approvedAt       DateTime?
  assigneeId       String?
  approvedById     String?
  youngPersonId    String?
  createdById      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  assignee         Employee?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  approvedBy       Employee?          @relation("TaskApprover", fields: [approvedById], references: [id])
  youngPerson      YoungPerson?       @relation(fields: [youngPersonId], references: [id])

  @@index([status, priority])
  @@index([approvalStatus])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([createdById])
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  authorId    String?
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([isPinned])
}

// ─── Dashboard Widgets ────────────────────────────────────────────────────────

model Widget {
  id         String   @id @default(cuid())
  userId     String
  title      String
  period     String   // e.g. "last_7_days", "last_30_days", "this_month", "this_year"
  reportsOn  String   // e.g. "tasks", "approvals", "young_people"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
